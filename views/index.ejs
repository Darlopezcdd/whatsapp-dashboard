<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Whatsapp Masivo</title>
    <!-- Use Inter font for a clean, modern look -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #25D366; /* WhatsApp brand */
            --primary-hover: #1EBE5D;
            --bg-color: #FAFAFA;
            --card-bg: #FFFFFF;
            --text-dark: #1F2937;
            --text-muted: #6B7280;
            --border-color: #E5E7EB;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.025);
            --radius-md: 12px;
            --radius-lg: 16px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            -webkit-font-smoothing: antialiased;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 600px; /* Kept narrow for elegance */
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .header {
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 0.5rem;
            letter-spacing: -0.025em;
        }

        .header p {
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 400;
        }

        /* Glass / Clean Cards */
        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: var(--shadow-md);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .card h2 {
            font-size: 1.15rem;
            font-weight: 500;
            margin-bottom: 1.25rem;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        label {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-muted);
        }

        textarea, input[type="file"] {
            width: 100%;
            padding: 1rem;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            color: var(--text-dark);
            transition: border-color 0.2s, box-shadow 0.2s;
            background-color: #F9FAFB;
        }

        textarea {
            resize: vertical;
            min-height: 120px;
            line-height: 1.5;
        }

        textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 211, 102, 0.1);
            background-color: #FFFFFF;
        }

        /* Input file styling */
        input[type="file"]::file-selector-button {
            border: none;
            background: #E5E7EB;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            color: var(--text-dark);
            cursor: pointer;
            font-weight: 500;
            transition: background 0.2s;
            margin-right: 1rem;
        }

        input[type="file"]::file-selector-button:hover {
            background: #D1D5DB;
        }

        /* Buttons */
        button {
            background-color: var(--text-dark);
            color: #FFFFFF;
            border: none;
            padding: 0.875rem 1.5rem;
            border-radius: var(--radius-md);
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 0.5rem;
        }

        button:hover {
            background-color: #000000;
            box-shadow: var(--shadow-md);
        }

        .btn-trigger {
            background-color: var(--primary);
            color: white;
            font-size: 1.1rem;
            font-weight: 600;
            padding: 1.2rem;
            border-radius: var(--radius-lg);
            margin-top: 1rem;
            box-shadow: 0 4px 14px rgba(37, 211, 102, 0.3);
        }

        .btn-trigger:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
        }

        /* Toast Notifications */
        .toast-container {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 50;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .toast {
            background: #FFFFFF;
            color: var(--text-dark);
            padding: 1rem 1.5rem;
            border-radius: 50px;
            box-shadow: var(--shadow-lg);
            font-size: 0.9rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.3s ease, transform 0.3s ease;
            border: 1px solid var(--border-color);
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast.success { border-left: 4px solid var(--primary); }
        .toast.error { border-left: 4px solid #ef4444; }

        /* Loader */
        .spinner {
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top: 2px solid white;
            width: 16px;
            height: 16px;
            animation: spin 1s linear infinite;
            display: none;
            margin-left: 8px;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        button.loading span { display: none; }
        button.loading .spinner { display: inline-block; }

    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <h1>Envío Masivo</h1>
            <p>Configura el contenido y dispara el flujo</p>
        </div>

        <!-- Paso 1: Lista -->
        <div class="card">
            <h2>👥 1. Lista de Contactos</h2>
            <div class="form-group">
                <label>Subir Nuevo Listado (Excel o CSV)</label>
                <input type="file" id="newListadoFile" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel">
                <button type="button" id="btnListado" onclick="uploadListado()">
                    <span>Subir Lista a Drive</span>
                    <div class="spinner"></div>
                </button>
            </div>
            
            <% if (listados && listados.length > 0) { %>
            <div style="margin-top: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
                <label style="display: block; margin-bottom: 0.75rem;">O elige un listado anterior:</label>
                <div class="list-container" style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <% listados.forEach(listado => { %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: #F9FAFB; border: 1px solid var(--border-color); border-radius: var(--radius-md);">
                            <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.9rem; font-weight: 500; max-width: 70%;"><%= listado.name %></div>
                            <button type="button" onclick="reuseFile('<%= listado.id %>', 'listado', this)" style="width: auto; padding: 0.4rem 0.8rem; margin: 0; font-size: 0.8rem; background-color: var(--card-bg); color: var(--text-dark); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">Reutilizar</button>
                        </div>
                    <% }) %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- Paso 2: Texto -->
        <div class="card">
            <h2>📝 2. Mensaje de Texto</h2>
            <div class="form-group">
                <textarea id="newMessageText" placeholder="Escribe el mensaje que deseas enviar a los contactos..."></textarea>
                <button type="button" id="btnText" onclick="uploadText()">
                    <span>Guardar Texto en Drive</span>
                    <div class="spinner"></div>
                </button>
            </div>
        </div>

        <!-- Paso 3: Imagen -->
        <div class="card">
            <h2>🖼️ 3. Adjuntar Imagen (Opcional)</h2>
            <div class="form-group">
                <input type="file" id="newImageFile" accept="image/*">
                <button type="button" id="btnImage" onclick="uploadImage()">
                    <span>Subir Imagen a Drive</span>
                    <div class="spinner"></div>
                </button>
            </div>
        </div>

        <!-- Paso 4: Disparar -->
        <button class="btn-trigger" id="btnTrigger" onclick="triggerN8n()">
            <span>🚀 Iniciar Envío Automático</span>
            <div class="spinner"></div>
        </button>
    </div>

    <!-- Contenedor de Toasts -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        function showToast(message, isError = false) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${isError ? 'error' : 'success'}`;
            toast.innerHTML = (isError ? '❌ ' : '✅ ') + message;
            
            container.appendChild(toast);
            
            // Animate in
            setTimeout(() => toast.classList.add('show'), 10);
            
            // Remove after 4s
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        function toggleLoading(btnId, isLoading) {
            const btn = document.getElementById(btnId);
            if(isLoading) {
                btn.classList.add('loading');
                btn.disabled = true;
            } else {
                btn.classList.remove('loading');
                btn.disabled = false;
            }
        }

        async function uploadListado() {
            const fileInput = document.getElementById('newListadoFile');
            if (fileInput.files.length === 0) return showToast('Selecciona un archivo Excel o CSV', true);
            
            toggleLoading('btnListado', true);
            const formData = new FormData();
            formData.append('listadoFile', fileInput.files[0]);

            try {
                const res = await fetch('/api/upload/listado', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Lista subida correctamente.');
                    setTimeout(() => location.reload(), 1500);
                } else throw new Error(data.error);
            } catch (err) {
                showToast(err.message || 'Error al subir la lista', true);
                toggleLoading('btnListado', false);
            }
        }

        async function reuseFile(fileId, type, btnElement) {
            const originalText = btnElement.innerText;
            btnElement.innerText = 'Cargando...';
            btnElement.disabled = true;

            try {
                const res = await fetch('/api/reuse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fileId, type })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Listado seleccionado como activo.');
                    setTimeout(() => location.reload(), 1500);
                } else throw new Error(data.error);
            } catch (err) {
                showToast(err.message || 'Error seleccionando archivo', true);
                btnElement.innerText = originalText;
                btnElement.disabled = false;
            }
        }

        async function uploadText() {
            const content = document.getElementById('newMessageText').value;
            if (!content.trim()) return showToast('El mensaje no puede estar vacío', true);
            
            toggleLoading('btnText', true);
            try {
                const res = await fetch('/api/upload/text', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ messageContent: content })
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Mensaje guardado en Drive.');
                    document.getElementById('newMessageText').value = ''; // clear upon success
                } else throw new Error(data.error);
            } catch (err) {
                showToast(err.message || 'Error al guardar el mensaje', true);
            } finally {
                toggleLoading('btnText', false);
            }
        }

        async function uploadImage() {
            const fileInput = document.getElementById('newImageFile');
            if (fileInput.files.length === 0) return showToast('Selecciona una imagen primero', true);
            
            toggleLoading('btnImage', true);
            const formData = new FormData();
            formData.append('imageFile', fileInput.files[0]);

            try {
                const res = await fetch('/api/upload/image', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Imagen subida correctamente.');
                    fileInput.value = ''; // clear upon success
                } else throw new Error(data.error);
            } catch (err) {
                showToast(err.message || 'Error al subir la imagen', true);
            } finally {
                toggleLoading('btnImage', false);
            }
        }

        async function triggerN8n() {
            toggleLoading('btnTrigger', true);
            try {
                const res = await fetch('/api/trigger', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    showToast(data.message);
                } else throw new Error(data.error);
            } catch (err) {
                showToast(err.message || 'Error de conexión con n8n', true);
            } finally {
                toggleLoading('btnTrigger', false);
            }
        }
    </script>
</body>
</html>
