<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Whatsapp Masivo</title>
    <!-- Use Inter font for a clean, modern look -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #25D366; /* WhatsApp brand */
            --primary-hover: #1EBE5D;
            --bg-color: #FAFAFA;
            --card-bg: #FFFFFF;
            --text-dark: #1F2937;
            --text-muted: #6B7280;
            --border-color: #E5E7EB;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.025);
            --radius-md: 12px;
            --radius-lg: 16px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            -webkit-font-smoothing: antialiased;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 1100px;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .steps-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            align-items: start;
        }

        .header {
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-dark);
            margin-bottom: 0.5rem;
            letter-spacing: -0.025em;
        }

        .header p {
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 400;
        }

        /* Glass / Clean Cards */
        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: var(--shadow-md);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .card h2 {
            font-size: 1.15rem;
            font-weight: 500;
            margin-bottom: 1.25rem;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        label {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-muted);
        }

        textarea, input[type="file"] {
            width: 100%;
            padding: 1rem;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            color: var(--text-dark);
            transition: border-color 0.2s, box-shadow 0.2s;
            background-color: #F9FAFB;
        }

        textarea {
            resize: vertical;
            min-height: 120px;
            line-height: 1.5;
        }

        textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 211, 102, 0.1);
            background-color: #FFFFFF;
        }

        /* Input file styling */
        input[type="file"]::file-selector-button {
            border: none;
            background: #E5E7EB;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            color: var(--text-dark);
            cursor: pointer;
            font-weight: 500;
            transition: background 0.2s;
            margin-right: 1rem;
        }

        input[type="file"]::file-selector-button:hover {
            background: #D1D5DB;
        }

        /* Buttons */
        button {
            background-color: var(--text-dark);
            color: #FFFFFF;
            border: none;
            padding: 0.875rem 1.5rem;
            border-radius: var(--radius-md);
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 0.5rem;
        }

        button:hover {
            background-color: #000000;
            box-shadow: var(--shadow-md);
        }

        .btn-trigger {
            background-color: var(--primary);
            color: white;
            font-size: 1.1rem;
            font-weight: 600;
            padding: 1.2rem;
            border-radius: var(--radius-lg);
            margin-top: 1rem;
            box-shadow: 0 4px 14px rgba(37, 211, 102, 0.3);
        }

        .btn-trigger:hover {
            background-color: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
        }

        /* Toast Notifications */
        .toast-container {
            position: fixed;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 50;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .toast {
            background: #FFFFFF;
            color: var(--text-dark);
            padding: 1rem 1.5rem;
            border-radius: 50px;
            box-shadow: var(--shadow-lg);
            font-size: 0.9rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.3s ease, transform 0.3s ease;
            border: 1px solid var(--border-color);
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast.success { border-left: 4px solid var(--primary); }
        .toast.error { border-left: 4px solid #ef4444; }

        /* Loader */
        .spinner {
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top: 2px solid white;
            width: 16px;
            height: 16px;
            animation: spin 1s linear infinite;
            display: none;
            margin-left: 8px;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        button.loading span { display: none; }
        button.loading .spinner { display: inline-block; }

    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <h1>Envío Masivo</h1>
            <p>Configura el contenido y dispara el flujo</p>
        </div>

        <div class="steps-grid">
        <!-- Paso 1: Lista -->
        <div class="card">
            <h2>👥 1. Lista de Contactos</h2>
            <div class="form-group">
                <label>Subir Nuevo Listado (Excel o CSV)</label>
                <input type="file" id="newListadoFile" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel">
            </div>
            <div style="margin-top: 1.2rem; padding: 0.8rem; background: #F3F4F6; border-radius: 8px; font-size: 0.85rem; color: #4B5563; border-left: 3px solid #6B7280;">
                <p>ℹ️ <strong>Nota:</strong> Sube archivo o marca uno del historial. Si omites, se usa el último de Drive automáticamente.</p>
            </div>
            <% if (listados && listados.length > 0) { %>
            <div style="margin-top: 1.5rem;">
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Historial en Drive (Marca para Reutilizar):</p>
                <div style="display: flex; flex-direction: column; gap: 0.4rem; max-height: 150px; overflow-y: auto; padding-right: 0.5rem;">
                    <% listados.forEach((item, index) => { %>
                        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; padding: 0.3rem 0; border-bottom: 1px solid var(--border-color);">
                            <input type="radio" name="listadoSelect" value="<%= item.id %>">
                            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;" title="<%= item.name %>">📄 <%= item.name %></span>
                        </label>
                    <% }) %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- Paso 2: Texto -->
        <div class="card">
            <h2>📝 2. Mensaje de Texto</h2>
            <div class="form-group">
                <textarea id="newMessageText" placeholder="Escribe un mensaje nuevo aquí..."></textarea>
            </div>
            <% if (mensajes && mensajes.length > 0) { %>
            <div style="margin-top: 1.5rem;">
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Últimos 3 mensajes (Marca para Reutilizar):</p>
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <% mensajes.forEach(item => { %>
                        <label style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; padding: 0.4rem; background: #F9FAFB; border-radius: 6px; border: 1px solid var(--border-color);">
                            <input type="radio" name="mensajeSelect" value="<%= item.id %>" style="margin-top: 0.2rem;">
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-weight: 500; font-size: 0.8rem;"><%= item.name %></span>
                                <% if (item.description) { %>
                                    <span style="font-size: 0.75rem; color: #666; font-style: italic;"><%= item.description %>...</span>
                                <% } %>
                            </div>
                        </label>
                    <% }) %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- Paso 3: Imagen -->
        <div class="card">
            <h2>🖼️ 3. Adjuntar Imagen (Opcional)</h2>
            <div class="form-group">
                <input type="file" id="newImageFile" accept="image/*">
            </div>
            <% if (imagenes && imagenes.length > 0) { %>
            <div style="margin-top: 1.5rem;">
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Últimas 3 imágenes (Marca para Reutilizar):</p>
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <% imagenes.forEach(item => { %>
                        <label style="display: flex; align-items: center; gap: 0.6rem; font-size: 0.85rem; cursor: pointer; padding: 0.4rem; background: #F9FAFB; border-radius: 6px; border: 1px solid var(--border-color);">
                            <input type="radio" name="imagenSelect" value="<%= item.id %>">
                            <% if (item.thumbnailLink) { %>
                                <img src="<%= item.thumbnailLink %>" alt="thumb" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;">
                            <% } else { %>
                                <div style="width: 40px; height: 40px; background: #E5E7EB; border-radius: 4px; display: flex; align-items: center; justify-content: center;">🖼️</div>
                            <% } %>
                            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;" title="<%= item.name %>"><%= item.name %></span>
                        </label>
                    <% }) %>
                </div>
            </div>
            <% } %>
        </div>
        </div> <!-- Fin de steps-grid -->

        <!-- Paso 4: Disparar -->
        <button class="btn-trigger" id="btnTrigger" onclick="executeFlow()">
            <span>🚀 Iniciar Envío Automático</span>
            <div class="spinner"></div>
        </button>r"></div>
        </button>
    </div>

    <!-- Contenedor de Toasts -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        function showToast(message, isError = false) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${isError ? 'error' : 'success'}`;
            toast.innerHTML = (isError ? '❌ ' : '✅ ') + message;
            
            container.appendChild(toast);
            
            setTimeout(() => toast.classList.add('show'), 10);
            
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        function toggleLoading(btnId, isLoading) {
            const btn = document.getElementById(btnId);
            if(isLoading) {
                btn.classList.add('loading');
                btn.disabled = true;
            } else {
                btn.classList.remove('loading');
                btn.disabled = false;
            }
        }

        async function doUpload(endpoint, formData) {
            const res = await fetch(endpoint, { method: 'POST', body: formData });
            const data = await res.json();
            if(!data.success) throw new Error(data.error || 'Error en subida');
        }

        async function doUploadJson(endpoint, payload) {
            const res = await fetch(endpoint, { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if(!data.success) throw new Error(data.error || 'Error en subida de texto');
        }

        async function doReuse(fileId, type) {
            const res = await fetch('/api/reuse', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ fileId, type })
            });
            const data = await res.json();
            if(!data.success) throw new Error(data.error || `Error reutilizando ${type}`);
        }

        async function executeFlow() {
            toggleLoading('btnTrigger', true);
            try {
                // 1. Listado
                const listadoFile = document.getElementById('newListadoFile').files[0];
                const listadoChecked = document.querySelector('input[name="listadoSelect"]:checked');
                if (listadoFile) {
                    showToast('Subiendo nuevo listado...');
                    const fd = new FormData(); fd.append('listadoFile', listadoFile);
                    await doUpload('/api/upload/listado', fd);
                } else if (listadoChecked) {
                    showToast('Reutilizando listado...');
                    await doReuse(listadoChecked.value, 'listado');
                }

                // 2. Texto
                const textContent = document.getElementById('newMessageText').value;
                const textChecked = document.querySelector('input[name="mensajeSelect"]:checked');
                if (textContent.trim()) {
                    showToast('Guardando nuevo mensaje...');
                    await doUploadJson('/api/upload/text', { messageContent: textContent });
                } else if (textChecked) {
                    showToast('Reutilizando mensaje...');
                    await doReuse(textChecked.value, 'message');
                }

                // 3. Imagen
                const imageFile = document.getElementById('newImageFile').files[0];
                const imageChecked = document.querySelector('input[name="imagenSelect"]:checked');
                if (imageFile) {
                    showToast('Subiendo nueva imagen...');
                    const fd = new FormData(); fd.append('imageFile', imageFile);
                    await doUpload('/api/upload/image', fd);
                } else if (imageChecked) {
                    showToast('Reutilizando imagen...');
                    await doReuse(imageChecked.value, 'image');
                }

                // 4. Trigger n8n
                showToast('🚀 Llamando a n8n...');
                const res = await fetch('/api/trigger', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    showToast(data.message);
                    setTimeout(() => location.reload(), 2000);
                } else throw new Error(data.error);

            } catch (err) {
                showToast(err.message || 'Error durante el flujo', true);
            } finally {
                toggleLoading('btnTrigger', false);
            }
        }
    </script>
</body>
</html>
